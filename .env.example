# ========================================
# SDR IA SOLARPRIME - CONFIGURAÇÕES
# ========================================

# === EVOLUTION API ===
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE_NAME=SDR IA SolarPrime

# === MESSAGE SPLITTER ===
# Divisão inteligente de mensagens
ENABLE_MESSAGE_SPLITTER=true
MESSAGE_MAX_LENGTH=250  # Aumentado para melhor preservação de frases
ENABLE_SMART_SPLITTING=true  # Usar NLTK para divisão por frases
SMART_SPLITTING_FALLBACK=true  # Usar fallback se NLTK falhar

# === MESSAGE BUFFER ===
ENABLE_MESSAGE_BUFFER=true
MESSAGE_BUFFER_TIMEOUT=30.0  # Tempo em segundos para agrupar mensagens

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# === OPENAI ===
OPENAI_API_KEY=your-openai-key-here

# === GOOGLE GEMINI ===
GOOGLE_API_KEY=your-gemini-key-here

# === ANTHROPIC ===
ANTHROPIC_API_KEY=your-anthropic-key-here

# === KOMMO CRM ===
KOMMO_DOMAIN=your-domain.kommo.com
KOMMO_ACCESS_TOKEN=your-access-token

# === REDIS (Opcional) ===
REDIS_URL=redis://localhost:6379/0

# === POSTGRESQL (Opcional) ===
POSTGRESQL_URL=postgresql://user:password@localhost:5432/dbname

# === CONFIGURAÇÕES DE TIMING ===
RESPONSE_DELAY_MIN=1.5
RESPONSE_DELAY_MAX=3.0
RESPONSE_DELAY_THINKING=5.0
TYPING_DURATION_SHORT=2.0
TYPING_DURATION_MEDIUM=3.5
TYPING_DURATION_LONG=5.0