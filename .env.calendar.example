# ==============================================
# GOOGLE CALENDAR - CONFIGURAÇÕES ESSENCIAIS
# ==============================================
# Copie este arquivo para .env e preencha com suas credenciais

# 1. HABILITAR FUNCIONALIDADES DO CALENDÁRIO
# ------------------------------------------
ENABLE_CALENDAR_AGENT=true
ENABLE_CALENDAR_INTEGRATION=true
ENABLE_SDR_TEAM=true

# 2. SERVICE ACCOUNT - CREDENCIAIS
# ------------------------------------------
# Obtenha no Console do Google Cloud:
# https://console.cloud.google.com/iam-admin/serviceaccounts

GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-service-account@seu-projeto.iam.gserviceaccount.com
GOOGLE_PROJECT_ID=seu-projeto-id
GOOGLE_PRIVATE_KEY_ID=chave-privada-id-aqui
GOOGLE_CLIENT_ID=client-id-aqui
GOOGLE_CALENDAR_ID=primary  # ou ID específico do calendário

# 3. CHAVE PRIVADA DO SERVICE ACCOUNT
# ------------------------------------------
# IMPORTANTE: Copie a chave privada EXATAMENTE como está no JSON
# Incluindo -----BEGIN PRIVATE KEY----- e -----END PRIVATE KEY-----
# Use aspas duplas ao redor da chave completa

GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
COLE_SUA_CHAVE_PRIVADA_AQUI
MANTENHA_AS_QUEBRAS_DE_LINHA
-----END PRIVATE KEY-----"

# 4. CONFIGURAÇÕES OPCIONAIS
# ------------------------------------------
# Desabilitar Google Calendar (útil para testes)
DISABLE_GOOGLE_CALENDAR=false

# Domain-wide delegation (apenas se você tem Google Workspace)
# GOOGLE_WORKSPACE_USER_EMAIL=usuario@suaempresa.com

# 5. VERIFICAÇÃO RÁPIDA
# ------------------------------------------
# Execute o teste para verificar se tudo está funcionando:
# python test_google_calendar.py

# DICAS DE TROUBLESHOOTING:
# ------------------------
# 1. Erro de autenticação: Verifique se a chave privada está correta
# 2. Erro 403: Ative a API do Google Calendar no Console
# 3. Service Account não pode convidar: Normal, precisa de Domain-Wide Delegation
# 4. Erro ao criar Meet: Verifique se a API está ativada